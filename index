    <style>
        :root {
            --bg-color: #0a0f16;
            --surface-color: #121b26;
            --primary-color: #00d2ff;
            --secondary-color: #3a7bd5;
            --text-main: #f8f9fa;
            --text-muted: #bac4d1; /* Brightened for better dark mode visibility */
            --font-main: 'Poppins', sans-serif;
            --font-code: 'Fira Code', monospace;
        }

        body, html {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-main);
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-color);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--secondary-color);
            border-radius: 4px;
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
        }
        
        /* Force Bootstrap to use our lighter muted color */
        .text-muted {
            color: var(--text-muted) !important;
        }
        
        .text-gradient {
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .code-font {
            font-family: var(--font-code);
            color: var(--primary-color);
        }

        /* Navigation */
        .navbar {
            background: rgba(10, 15, 22, 0.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            transition: all 0.3s ease;
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-main) !important;
            letter-spacing: 1px;
        }
        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 500;
            transition: color 0.3s;
            position: relative;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--primary-color) !important;
        }
        .navbar-toggler {
            border-color: rgba(255,255,255,0.1);
            color: var(--text-main);
        }
        .navbar-toggler:focus {
            box-shadow: none;
        }

        /* Sections & Spacing */
        section {
            padding: 100px 0;
            position: relative;
        }

        /* Hero Section */
        #hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }
        .hero-blob {
            position: absolute;
            width: 500px;
            height: 500px;
            background: linear-gradient(180deg, rgba(0, 210, 255, 0.1) 0%, rgba(58, 123, 213, 0.1) 100%);
            filter: blur(80px);
            border-radius: 50%;
            z-index: 0;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: float 10s ease-in-out infinite;
        }
        .hero-content {
            z-index: 1;
            position: relative;
        }
        
        /* Profile Image */
        .img-container {
            position: relative;
            width: 350px;
            height: 350px;
            margin: 0 auto;
            border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            padding: 5px;
            box-shadow: 0 0 40px rgba(0, 210, 255, 0.2);
            animation: morph 8s ease-in-out infinite alternate;
        }
        .img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: inherit;
        }

        @keyframes morph {
            0% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
            33% { border-radius: 50% 50% 20% 80% / 25% 80% 20% 75%; }
            66% { border-radius: 80% 20% 50% 50% / 70% 30% 70% 30%; }
            100% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
        }
        @keyframes float {
            0% { transform: translate(-50%, -50%) scale(1); }
            50% { transform: translate(-50%, -55%) scale(1.05); }
            100% { transform: translate(-50%, -50%) scale(1); }
        }

        /* Buttons */
        .btn-custom {
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            color: #fff;
            border: none;
            padding: 12px 30px;
            border-radius: 50px;
            font-weight: 600;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .btn-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 210, 255, 0.3);
            color: #fff;
        }
        .btn-outline-custom {
            background: transparent;
            color: var(--text-main);
            border: 2px solid var(--primary-color);
            padding: 10px 28px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s;
        }
        .btn-outline-custom:hover {
            background: rgba(0, 210, 255, 0.1);
            color: var(--primary-color);
            transform: translateY(-3px);
        }

        /* Stats Cards */
        .stat-card {
            background: var(--surface-color);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            transition: transform 0.3s;
